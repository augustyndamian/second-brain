{
  "name": "second-brain",
  "private": true,
  "version": "0.0.2",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "build:cli": "pnpm --filter @second-brain/cli build",
    "build:gui": "pnpm --filter @second-brain/gui build && pnpm --filter @second-brain/gui package",
    "install:local": "node ./scripts/install-local.mjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "@types/node": "^22.10.0"
  }
}
