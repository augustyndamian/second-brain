{
  "name": "@second-brain/gui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build:main": "node ./scripts/build-main.mjs",
    "build": "pnpm build:main && pnpm build:renderer",
    "package": "node ./scripts/package-app.mjs",
    "start": "electron .",
    "start:dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && pnpm build:main && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.electron.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@second-brain/core": "workspace:*",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "chokidar": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@electron/packager": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "esbuild": "^0.24.0",
    "wait-on": "^8.0.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
